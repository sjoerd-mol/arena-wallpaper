# Are.na credentials
# Generate a personal access token at: are.na/settings/personal-access-tokens
ARENA_ACCESS_TOKEN=your_personal_access_token_here

# Slug of the Are.na channel to pull images from
# Found in the channel URL: are.na/username/channel-slug
ARENA_BOARD_SLUG=your-channel-slug

# --- Mac wallpaper ---

# Absolute path to the local images folder (downloaded originals)
# Defaults to images/ inside the project folder if left unset
IMAGE_DIR=/absolute/path/to/arena-wallpaper/images

# How the image is displayed on screen
# Options: center | fill | fit | stretch | auto
# center = actual pixel size, no scaling (recommended)
WALLPAPER_SCALE=center

# Width in px to resize images to for the display cache (0 = no resize)
# 720 is a good balance between quality and memory on Retina displays
TARGET_WIDTH=720

# Set a different random image per connected screen
PER_SCREEN_RANDOM=true

# Avoid repeating images shown within the last N days (0 = no memory)
RECENT_DAYS=7

# --- iPhone wallpaper (iCloud) ---

# Absolute path to the iCloud folder where iPhone wallpapers are written
# Must be inside your iCloud Drive so the iPhone can read them via Shortcuts
IPHONE_IMAGE_DIR=/Users/YOUR_USERNAME/Library/Mobile Documents/com~apple~CloudDocs/Documents/arena-wallpaper/images-iphone

# Canvas dimensions — iPhone 17 Pro portrait (1206 x 2622)
# Adjust for your model: iPhone 16 Pro = 1206 x 2622, iPhone 15 Pro = 1179 x 2556
IPHONE_CANVAS_W=1206
IPHONE_CANVAS_H=2622

# Image width as a fraction of canvas width (0.75 = 75%)
# Images are centred on a black canvas; low-res images appear smaller by design
IPHONE_IMAGE_SCALE=0.75
