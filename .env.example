# Are.na credentials
# Generate a personal access token at: are.na/settings/personal-access-tokens
ARENA_ACCESS_TOKEN=your_personal_access_token_here

# Slug of the Are.na channel to pull images from
# Found in the channel URL: are.na/username/channel-slug
ARENA_BOARD_SLUG=your-channel-slug

# --- Mac wallpaper ---

# Local folder where downloaded originals are stored.
# Leave this line commented out to use the default: images/ inside the project folder.
# If you set a custom path, use the full absolute path (e.g. /Users/you/Pictures/arena).
# Tip: in Finder, Option+right-click any folder and choose "Copy ... as Pathname".
# IMAGE_DIR=

# How the image is displayed on screen.
# Options: center | fill | fit | stretch | auto
# center = actual pixel size, centred on screen, no scaling (recommended)
WALLPAPER_SCALE=center

# Width in pixels for the display cache — a resized copy used for wallpaper display.
# Originals in images/ are never modified. Images narrower than this value are never upscaled.
# 720 works well for most Are.na images on Retina displays with center scaling.
TARGET_WIDTH=720

# Set a different random image on each connected screen
PER_SCREEN_RANDOM=true

# Avoid repeating images shown within the last N days (0 = no memory)
RECENT_DAYS=7

# --- iPhone wallpaper (iCloud) ---

# Where iPhone wallpapers are written on your Mac.
# This MUST be a folder inside your iCloud Drive so your iPhone can read the files.
#
# iCloud Drive lives at:
#   /Users/YOUR_USERNAME/Library/Mobile Documents/com~apple~CloudDocs/
#
# Create a folder for these wallpapers inside iCloud Drive, then paste its full path here.
# Tip: in Finder, Option+right-click the folder and choose "Copy ... as Pathname".
#
# Example (replace YOUR_USERNAME with the output of: whoami):
IPHONE_IMAGE_DIR=/Users/YOUR_USERNAME/Library/Mobile Documents/com~apple~CloudDocs/Documents/arena-wallpaper/images-iphone

# Canvas dimensions in pixels — must match your iPhone model's screen resolution.
# iPhone 17 Pro / 16 Pro : 1206 x 2622
# iPhone 15 Pro / 14 Pro : 1179 x 2556
IPHONE_CANVAS_W=1206
IPHONE_CANVAS_H=2622

# Image width as a fraction of the canvas width (0.75 = 75%).
# Images are centred on a black canvas. Low-resolution images appear smaller by design —
# they display at their native scale rather than being stretched to fill.
IPHONE_IMAGE_SCALE=0.75
